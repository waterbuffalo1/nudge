{
  "name": "nudge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check": "npm run lint && npm run test && npm run build",
    "submissions": "node --import tsx scripts/list-submissions.ts open",
    "submissions:done-list": "node --import tsx scripts/list-submissions.ts done",
    "submissions:done": "node --import tsx scripts/mark-submission-done.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
